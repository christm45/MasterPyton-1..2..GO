<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#06060f</item>
        <item name="colorPrimaryDark">#06060f</item>
        <item name="colorAccent">#00f0ff</item>
        <item name="android:navigationBarColor">#06060f</item>
        <item name="android:statusBarColor">#06060f</item>
        <item name="android:windowBackground">#06060f</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:navigationBarColor">#06060f</item>
        <item name="android:statusBarColor">#06060f</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">#06060f</item>
    </style>
</resources>